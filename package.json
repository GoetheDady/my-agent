  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/bun": "latest",
    "eslint": "^10.3.0",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.59.2"
  },
  "dependencies": {
    "@ai-sdk/deepseek": "^2.0.33",
    "@lancedb/lancedb": "^0.27.2",
    "ai": "^6.0.175"
  }
}
