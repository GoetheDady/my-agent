{
  "name": "my-agent",
  "version": "2.0.0",
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/main.ts",
    "start": "bun run src/main.ts",
    "test": "bun test",
    "test:watch": "bun test --watch",
